/target
/xtask/target
/crates/dstu-core/fuzz/target
/crates/dstu-core/fuzz/corpus
/crates/dstu-core/fuzz/artifacts
**/*.rs.bk
/xtask/Cargo.lock
/crates/dstu-core/fuzz/Cargo.lock
*.pdb
.claude.local.md
/.claude/

# Oracle-harness build artifacts and fetched dependencies (Java/.NET) — fetched fresh via
# Maven/NuGet at build time (see tests/oracle-harness/*/README or TASKS.md "Infrastructure"),
# never vendored or committed, same rule as /oracles below.
/tests/oracle-harness/java/lib/
/tests/oracle-harness/java/out/
/tests/oracle-harness/java/target/
/tests/oracle-harness/dotnet/bin/
/tests/oracle-harness/dotnet/obj/
# Compiled C oracle-harness drivers (gcc output built ad hoc per the build command in each .c
# file's own doc comment, never checked in) - same convention as the two rules above.
/tests/oracle-harness/*/*.exe
/tests/oracle-harness/*/*.o

# Third-party reference implementations, used only as oracles for local test-vector
# cross-verification (see oracles/README.md, DECISIONS.md D-02/D-06). Never vendored into
# crates/, never committed or published — regardless of the upstream license.
# oracles/README.md itself stays tracked so the reasoning survives a fresh clone.
/oracles/*
!/oracles/README.md
